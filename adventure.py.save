





























def start_game():
    print("--- رحلة في قلب الصحراء ---")
    print("أنت الآن تقف في وسط الصحراء، والشمس في كبد السماء.")
    print("أمامك طريقان: طريق يؤدي إلى 'واحة خضراء'، وطريق يؤدي إلى 'كهف مظلم'.")
    
    choice = input("أي طريق ستختار؟ (واحة/كهف): ").lower()
    
    if choice == "واحة":
        oasis_path()
    elif choice == "كهف":
        cave_path()
    else:
        print("اختيار غير معروف، أعد المحاولة!")
        start_game()

def oasis_path():
    print("\nلقد اخترت الواحة. الماء بارد والأشجار وارفة الظلال.")
    print("أنت تستريح، لكنك تجد صندوقاً خشبياً قديماً تحت شجرة نخيل.")
    choice = input("هل تفتحه؟ (نعم/لا): ").lower()
    
    if choice == "نعم":
        print("\nتهانينا! وجدت كنزاً قديماً. لقد ربحت اللعبة!")
    else:
        print("\nقررت عدم المخاطرة. لقد نجوت ولكنك عدت للمنزل بيدين فارغتين.")

def cave_path():
    print("\nدخلت الكهف المظلم، الرؤية صعبة جداً.")
    print("فجأة، ظهر أمامك وحش صغير يطلب لغزاً ليسمح لك بالعبور.")

